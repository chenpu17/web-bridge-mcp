{
  "name": "@chenpu17/web-bridge-mcp",
  "version": "1.0.19",
  "description": "MCP server with proxy support for web search and fetch - Bridge intranet to internet",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "web-bridge-mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node scripts/add-shebang.cjs",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --project tsconfig.typecheck.json",
    "prepublishOnly": "npm run build && npm run lint && npm run test:unit"
  },
  "keywords": [
    "mcp",
    "proxy",
    "web-search",
    "web-fetch",
    "duckduckgo",
    "exa",
    "bocha",
    "intranet",
    "http-proxy",
    "ssl",
    "ai-search",
    "web-bridge"
  ],
  "author": "chenpu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chenpu17/web-bridge-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/chenpu17/web-bridge-mcp/issues"
  },
  "homepage": "https://github.com/chenpu17/web-bridge-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cheerio": "^1.2.0",
    "commander": "^12.0.0",
    "https-proxy-agent": "^7.0.0",
    "node-fetch": "^3.3.2",
    "turndown": "^7.2.0",
    "undici": "^6.24.1",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/turndown": "^5.0.5",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*",
    "scripts/add-shebang.cjs",
    "README.md",
    "LICENSE"
  ]
}
